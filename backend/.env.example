# Server
PORT=3001

# JWT Secrets — generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_64_byte_hex_secret

# AES-256-GCM master key — generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_MASTER_KEY=replace_with_32_byte_hex_key

# Gemini API key for AI analysis
GEMINI_API_KEY=your_gemini_api_key_here

# PDF access session expiry (minutes)
PDF_ACCESS_SESSION_MINUTES=30

# Upload directory for encrypted PDFs (relative to backend root)
UPLOAD_DIR=./uploads

# Max upload size in MB
MAX_FILE_SIZE_MB=10

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173

# JSON file store path (relative to backend root)
DB_FILE=./data/db.json
